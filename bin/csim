#!/usr/bin/env python3
"""csim - Crypto Simulation Engine runner."""
import sys
import os
from pathlib import Path


def main():
    if len(sys.argv) != 2:
        print("Usage: csim <config.yml>")
        sys.exit(1)

    config_path = Path(sys.argv[1]).resolve()
    if not config_path.exists():
        print(f"Error: config not found: {config_path}")
        sys.exit(1)

    # Add csim root to path
    csim_root = Path(__file__).resolve().parent.parent
    if str(csim_root) not in sys.path:
        sys.path.insert(0, str(csim_root))

    from core.sim_config import init_simcfg
    simcfg = init_simcfg(str(config_path))

    from core.universe import init_universe
    init_universe()

    from core.data_registry import get_data_registry
    dr = get_data_registry()

    # Phase 1: Initialize all data managers (registers fields + dependencies)
    print('=== Loading data ===')
    dmgr_instances = {}
    dmgr_ids = []
    for module_id, (module, cfg) in simcfg.modules.items():
        if cfg.get('handler') == 'datahandler':
            mgr = module.create(cfg)
            dmgr_instances[module_id] = mgr
            dmgr_ids.append(module_id)

    # Phase 2: Resolve DAG and load data in dependency order
    execution_order = dr.get_execution_order(dmgr_ids)
    print(f'  Execution order: {" -> ".join(execution_order)}')
    for mid in execution_order:
        if mid in dmgr_instances:
            dmgr_instances[mid].load_data()

    # Build portfolio tree and run
    print('=== Running simulation ===')
    from core import sim
    portfolio = simcfg.portfolio
    sim.run(portfolio)

    print('=== Done ===')


if __name__ == '__main__':
    main()
